<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemaestoquefx.FormularioHistoricoController">
   <children>
      <Pane prefHeight="70.0" prefWidth="800.0" style="-fx-background-color: #0f172a;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label layoutX="270.0" layoutY="18.0" text="Histórico de Vendas" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
         </children>
      </Pane>
      
      <Pane layoutX="20.0" layoutY="90.0" prefHeight="80.0" prefWidth="760.0" style="-fx-border-color: #cbd5e1; -fx-border-radius: 5px; -fx-background-color: #f8fafc; -fx-background-radius: 5px;" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
         <children>
            <Label layoutX="14.0" layoutY="6.0" text="Consulta por Data">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="30.0" spacing="15.0">
               <children>
                  <Label text="Data Início:">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dtInicio" prefWidth="140.0" />
                  <Label text="Data Fim:">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <DatePicker fx:id="dtFim" prefWidth="140.0" />
                  <Button mnemonicParsing="false" onAction="#pesquisarAction" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #3b82f6;" text="Pesquisar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </Pane>
      
      <TableView fx:id="tabelaHistorico" layoutX="20.0" layoutY="190.0" prefHeight="340.0" prefWidth="760.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="190.0" />
   </children>
</AnchorPane>