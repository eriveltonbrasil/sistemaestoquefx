<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemaestoquefx.FormularioEstoqueController">
   <children>
      <Pane prefHeight="80.0" prefWidth="750.0" style="-fx-background-color: #0f172a;">
         <children>
            <Label layoutX="240.0" layoutY="22.0" text="Controle de Estoque" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
         </children>
      </Pane>
      
      <Label layoutX="30.0" layoutY="100.0" text="Código:" />
      <TextField fx:id="txtCodigo" disable="true" layoutX="100.0" layoutY="96.0" prefHeight="25.0" prefWidth="80.0" />
      
      <Label layoutX="30.0" layoutY="140.0" text="Descrição:" />
      <TextField fx:id="txtDescricao" layoutX="100.0" layoutY="136.0" prefHeight="25.0" prefWidth="300.0" />
      <Button layoutX="420.0" layoutY="136.0" mnemonicParsing="false" onAction="#pesquisarAction" text="Pesquisar" />
      
      <Label layoutX="30.0" layoutY="180.0" text="Qtd. Atual:" />
      <TextField fx:id="txtQtdAtual" disable="true" layoutX="100.0" layoutY="176.0" prefHeight="25.0" prefWidth="80.0" />
      
      <Label layoutX="200.0" layoutY="180.0" text="Quantidade a Adicionar:" />
      <TextField fx:id="txtQtdAdicionar" layoutX="350.0" layoutY="176.0" prefHeight="25.0" prefWidth="80.0" />
      <Button layoutX="450.0" layoutY="176.0" mnemonicParsing="false" onAction="#adicionarEstoqueAction" style="-fx-background-color: #22c55e;" text="➕ Adicionar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      
      <TableView fx:id="tabelaProdutos" layoutX="30.0" layoutY="230.0" prefHeight="290.0" prefWidth="690.0" />
   </children>
</AnchorPane>