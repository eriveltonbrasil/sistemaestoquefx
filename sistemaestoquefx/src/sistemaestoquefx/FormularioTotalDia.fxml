<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="350.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemaestoquefx.FormularioTotalDiaController">
   <children>
      <Pane prefHeight="70.0" prefWidth="450.0" style="-fx-background-color: #0f172a;">
         <children>
            <Label layoutX="120.0" layoutY="18.0" text="Posição do Dia" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
         </children>
      </Pane>
      
      <Pane layoutX="30.0" layoutY="100.0" prefHeight="220.0" prefWidth="390.0" style="-fx-border-color: #cbd5e1; -fx-border-radius: 5px; -fx-background-color: #f8fafc; -fx-background-radius: 5px;">
         <children>
            <Label layoutX="30.0" layoutY="35.0" text="Data da Venda:">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            
            <DatePicker fx:id="dtDataVenda" layoutX="140.0" layoutY="30.0" prefHeight="30.0" prefWidth="130.0" />
            
            <Button layoutX="280.0" layoutY="30.0" mnemonicParsing="false" onAction="#pesquisarAction" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #3b82f6;" text="Pesquisar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            
            <Label layoutX="145.0" layoutY="110.0" text="Total de Vendas:">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            
            <TextField fx:id="txtTotalVenda" alignment="CENTER" disable="true" editable="false" layoutX="50.0" layoutY="140.0" prefHeight="50.0" prefWidth="290.0" promptText="R$ 0,00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #22c55e;" />
         </children>
      </Pane>
   </children>
</AnchorPane>