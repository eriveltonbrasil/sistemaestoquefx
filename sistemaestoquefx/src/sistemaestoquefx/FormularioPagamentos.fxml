<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sistemaestoquefx.FormularioPagamentosController">
   <children>
      <Pane prefHeight="60.0" prefWidth="400.0" style="-fx-background-color: #0f172a;">
         <children>
            <Label layoutX="123.0" layoutY="13.0" text="Pagamento" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
         </children>
      </Pane>
      
      <Label layoutX="40.0" layoutY="90.0" text="Total a Pagar (R$):">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtTotalPagar" alignment="CENTER" disable="true" editable="false" layoutX="40.0" layoutY="120.0" prefHeight="50.0" prefWidth="320.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" />
      
      <Label layoutX="40.0" layoutY="190.0" text="Dinheiro (R$):">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtDinheiro" alignment="CENTER" layoutX="170.0" layoutY="185.0" prefHeight="35.0" prefWidth="190.0">
         <font>
            <Font size="16.0" />
         </font>
      </TextField>
      
      <Label layoutX="40.0" layoutY="240.0" text="Cartão (R$):">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <TextField fx:id="txtCartao" alignment="CENTER" layoutX="170.0" layoutY="235.0" prefHeight="35.0" prefWidth="190.0">
         <font>
            <Font size="16.0" />
         </font>
      </TextField>
      
      <Label layoutX="40.0" layoutY="300.0" text="Troco (R$):">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="txtTroco" alignment="CENTER" disable="true" editable="false" layoutX="170.0" layoutY="290.0" prefHeight="45.0" prefWidth="190.0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #22c55e;" />
      
      <Button layoutX="40.0" layoutY="370.0" mnemonicParsing="false" onAction="#finalizarPagamentoAction" prefHeight="50.0" prefWidth="320.0" style="-fx-background-color: #22c55e;" text="FINALIZAR VENDA" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
   </children>
</AnchorPane>